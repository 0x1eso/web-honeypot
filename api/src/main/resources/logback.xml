<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- ISO 8601 UTC timestamp: core 모듈과 같은 시간 포맷 -->
            <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX, UTC} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>

    <logger name="org.jetbrains.exposed" level="WARN"/>
    <logger name="io.ktor" level="INFO"/>
    <!-- 분류기 백그라운드 잡 전용 로거 -->
    <logger name="com.honeypot.AttackClassifierLoop" level="INFO"/>
    <logger name="com.honeypot.AttackClassifier" level="INFO"/>
</configuration>
