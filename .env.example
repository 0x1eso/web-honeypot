# Web Honeypot — 환경 변수 템플릿
# 실제 사용 시 이 파일을 복사한 뒤 `.env` 로 저장하고 docker compose 가 자동으로 로드한다.
#   cp .env.example .env
#
# 주의: `.env` 는 git 추적 대상이 아니다 (.gitignore 참조).

# ------------------------------------------------------------
# api 서버 (Kotlin/Ktor) — 컨테이너 내부 환경 변수
# ------------------------------------------------------------

# SQLite DB 경로. core 모듈과 같은 볼륨(/data)을 마운트하므로 동일 경로를 가리켜야 한다.
DB_PATH=/data/honeypot.db

# CORS 화이트리스트 (CSV).
# Docker compose 안에서는 nginx 가 same-origin 으로 proxy 하므로 일반적으로 비워두거나
# 외부 dashboard origin 만 명시한다. anyHost() 금지.
# 예: ALLOWED_ORIGINS=https://dashboard.example.com,https://ops.example.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ------------------------------------------------------------
# dashboard (Vite) — 빌드 시점 환경 변수 (Dockerfile ARG 로 전달)
# ------------------------------------------------------------

# 운영(Docker)에서는 nginx 가 /api 를 api 컨테이너로 proxy 하므로 상대 경로 사용.
# 로컬 dev 서버(vite)에서는 직접 호출하려면 http://localhost:8081/api 로 override.
VITE_API_URL=/api
